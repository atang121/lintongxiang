# ===== 童邻市集 · 后端环境变量完整模板 =====
# 文件位置：server/.env
# 生产环境必须使用 NODE_ENV=production。不要提交真实 .env。

# ===== 运行环境 =====
PORT=3001
NODE_ENV=production
JWT_SECRET=change_this_to_random_string_at_least_32_chars
JWT_EXPIRES_IN=30d

# 可选：指定 SQLite 位置。留空时使用 server/data/swap.db。
SQLITE_DATA_DIR=
SQLITE_DB_PATH=

# 预约候补锁定小时数。默认 48。
EXCHANGE_ACTIVE_HOURS=48

# ===== 访问地址 =====
# 允许访问 API 的前端域名，多个用英文逗号分隔。
FRONTEND_URL=http://localhost:3000
# 后端公网地址，用于图片 URL、微信回调和签名。
SERVER_PUBLIC_URL=http://localhost:3001

# ===== 管理员 =====
ADMIN_TOKEN=change_this_admin_token
# 管理员手机号，多个用英文逗号分隔。该手机号注册/登录后会自动恢复管理员权限。
ADMIN_PHONES=15271090260

# ===== 腾讯云短信 =====
# 生产环境 SMS_ENABLED=true 时必须配置完整，否则拒绝发送且不会返回 preview_code。
SMS_ENABLED=true
TENCENT_SECRET_ID=your_tencent_cloud_api_secret_id
TENCENT_SECRET_KEY=your_tencent_cloud_api_secret_key
TENCENT_SMS_SDK_APP_ID=your_sms_sdk_app_id
TENCENT_SMS_SIGN=童邻市集
TENCENT_SMS_TEMPLATE_ID=your_template_id
TENCENT_SMS_REGION=ap-guangzhou

# 兼容旧字段：新配置优先使用 TENCENT_SMS_SDK_APP_ID。
TENCENT_SMS_APP_ID=

# ===== 邮件 / 反馈兜底 =====
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_authorization_code
SMTP_FROM="童邻市集 <your_email@example.com>"
FEEDBACK_RECEIVER=your_email@example.com
SUPPORT_EMAIL=your_email@example.com

# ===== 飞书集成 =====
# 群机器人：用于反馈、举报投诉等群通知。
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token
# 多维表格：用于反馈存档、小区/运营配置、审核记录。
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BASE_TOKEN=your_feishu_base_token
FEISHU_FEEDBACK_TABLE_ID=your_feedback_table_id
FEISHU_COMMUNITIES_TABLE_ID=
FEISHU_OPS_CONFIG_TABLE_ID=
FEISHU_REVIEW_TABLE_ID=

# ===== 图片存储 =====
# local：保存到 server/data/uploads；cos：保存到腾讯云 COS。
STORAGE_PROVIDER=local
STORAGE_PUBLIC_BASE_URL=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=

# ===== 微信 / 分享 =====
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=xiangyang_kids_swap

# 预留：当前主要使用手机号验证码登录，开放平台登录暂未作为主流程。
OPEN_PLATFORM_APP_ID=
OPEN_PLATFORM_APP_SECRET=

# ===== 腾讯地图 =====
TENCENT_MAP_KEY=
