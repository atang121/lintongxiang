# ===== 微信配置 =====
WECHAT_APP_ID=wx_your_appid_here
WECHAT_APP_SECRET=your_appsecret_here
WECHAT_TOKEN=your_token_here

# ===== 微信开放平台（网站应用登录）=====
OPEN_PLATFORM_APP_ID=wx_your_open_appid_here
OPEN_PLATFORM_APP_SECRET=your_open_appsecret_here

# ===== 腾讯地图 =====
TENCENT_MAP_KEY=your_tencent_map_key_here

# ===== JWT =====
# ⚠️ 必须修改为强随机字符串（至少32字符），否则服务拒绝启动
JWT_SECRET=change_this_to_random_string_at_least_32_chars
JWT_EXPIRES_IN=30d

# ===== 服务端口 =====
PORT=3001
NODE_ENV=development

# ===== 前端地址（用于 CORS）=====
FRONTEND_URL=http://localhost:3000

# ===== 腾讯云短信 =====
# 设置 SMS_ENABLED=true 启用真实短信（需要腾讯云账号）
# 不设置或设置为 false 时开发环境使用预览模式；生产环境不会返回页面验证码
SMS_ENABLED=false
TENCENT_SECRET_ID=your_tencent_cloud_secret_id
TENCENT_SECRET_KEY=your_tencent_cloud_secret_key
TENCENT_SMS_SDK_APP_ID=your_sms_sdk_app_id
TENCENT_SMS_SIGN=童邻市集
TENCENT_SMS_TEMPLATE_ID=your_template_id
TENCENT_SMS_REGION=ap-guangzhou

# ===== 邮件验证码 / 反馈通知 =====
# 发件示例可用 QQ 邮箱 SMTP，SMTP_PASS 填邮箱"授权码"而不是登录密码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_authorization_code_here
SMTP_FROM="童邻市集 <your_email@example.com>"
# 反馈通知默认发给 SMTP_USER，也可单独指定
FEEDBACK_RECEIVER=your_email@example.com
SUPPORT_EMAIL=your_email@example.com

# ===== 服务器公网地址（用于微信分享签名）=====
SERVER_PUBLIC_URL=https://your-domain.com

# ===== 管理员 =====
# 仅在生产环境使用，格式：任意字符串
ADMIN_TOKEN=your_admin_token_here
# 管理员手机号，多个用英文逗号分隔。配置后该手机号注册/登录会自动恢复管理员权限。
ADMIN_PHONES=15271090260

# ===== 飞书集成 =====
# 飞书群机器人 Webhook（群通知）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token
# 飞书应用凭证（多维表格存档）
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BASE_TOKEN=your_feishu_base_token
FEISHU_FEEDBACK_TABLE_ID=your_feedback_table_id
# 飞书多维表格-小区配置表（可选）
FEISHU_COMMUNITIES_TABLE_ID=your_communities_table_id

# ===== 腾讯云 COS 对象存储（可选）=====
# 不配置则使用本地文件存储
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your_bucket_name
COS_REGION=ap-guangzhou
