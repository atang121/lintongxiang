# ===== 微信配置 =====
WECHAT_APP_ID=wx_your_appid_here
WECHAT_APP_SECRET=your_appsecret_here
WECHAT_TOKEN=your_token_here

# ===== 微信开放平台（网站应用登录）=====
OPEN_PLATFORM_APP_ID=wx_your_open_appid_here
OPEN_PLATFORM_APP_SECRET=your_open_appsecret_here

# ===== 腾讯地图 =====
TENCENT_MAP_KEY=your_tencent_map_key_here

# ===== JWT =====
JWT_SECRET=change_this_to_random_string_at_least_32_chars
JWT_EXPIRES_IN=30d

# ===== 服务端口 =====
PORT=3001
NODE_ENV=development

# ===== 前端地址（用于 CORS）=====
FRONTEND_URL=http://localhost:3000

# ===== 邮件验证码 / 反馈通知 =====
# 发件示例可用 QQ 邮箱 SMTP，SMTP_PASS 填邮箱“授权码”而不是登录密码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=273576151@qq.com
SMTP_PASS=your_smtp_authorization_code_here
SMTP_FROM="邻里童享 <273576151@qq.com>"
# 反馈通知默认发给 SMTP_USER，也可单独指定
FEEDBACK_RECEIVER=273576151@qq.com
SUPPORT_EMAIL=273576151@qq.com

# ===== 服务器公网地址（用于微信分享签名）=====
SERVER_PUBLIC_URL=https://your-domain.com
