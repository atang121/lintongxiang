# ============================================================
# 邻里童享 - 生产环境变量模板
# 复制为 .env 后填入真实值，切勿提交 .env 到 Git
# ============================================================

NODE_ENV=production
PORT=3001

# JWT 密钥（随机字符串，建议 64 位）
JWT_SECRET=your-very-long-random-secret-here

# 前端域名（Vercel 部署后填入，多个用英文逗号分隔）
FRONTEND_URL=https://your-app.vercel.app

# 服务器公网地址（Railway/Render 部署后填入）
# 用于本地图片的访问前缀（如果用 COS 则不重要）
SERVER_PUBLIC_URL=https://your-backend.railway.app

# ---- SMTP 邮件（QQ邮箱）----
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=273576151@qq.com
SMTP_PASS=你的QQ邮箱授权码（不是登录密码）
SMTP_FROM=邻里童享 <273576151@qq.com>
FEEDBACK_RECEIVER=273576151@qq.com

# ---- 腾讯云 COS 图片存储（强烈建议开启，否则重启丢图）----
STORAGE_PROVIDER=cos
COS_SECRET_ID=你的SecretId
COS_SECRET_KEY=你的SecretKey
COS_BUCKET=your-bucket-ap-chengdu
COS_REGION=ap-chengdu
# 可选：自定义 CDN 域名
# COS_PUBLIC_BASE_URL=https://cdn.your-domain.com

# ---- 飞书集成（可选，未配置则降级到本地）----
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx
FEISHU_BASE_TOKEN=你的多维表格token
FEISHU_FEEDBACK_TABLE_ID=tbl_反馈表id
FEISHU_COMMUNITIES_TABLE_ID=tbl_小区配置表id
# FEISHU_COMMUNITY_SUBMISSION_TABLE_ID=tbl_小区申请表id
# FEISHU_REVIEW_TABLE_ID=tbl_审核表id
# FEISHU_OPS_CONFIG_TABLE_ID=tbl_运营配置表id
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ---- 微信登录（可选）----
# WX_APP_ID=wx_xxxxxx
# WX_APP_SECRET=xxxxxxxxxxxxxxxx
